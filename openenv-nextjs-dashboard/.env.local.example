# Copy this file to .env.local and set your API URL

# Point to your running OpenEnv FastAPI server
# Local dev:
NEXT_PUBLIC_API_URL=http://localhost:7860

# HuggingFace Spaces:
# NEXT_PUBLIC_API_URL=https://your-space.hf.space

# Vercel production:
# NEXT_PUBLIC_API_URL=https://your-openenv-space.hf.space
